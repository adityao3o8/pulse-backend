# Copy to .env for local (non-docker) runs.
# Inside docker-compose these are supplied by the compose file instead.

# CRM database (the CRM never connects to the channel/persona DB).
DATABASE_URL=postgresql+psycopg2://pulse:pulse@localhost:5432/pulse_crm

# Channel service base URL — /seed calls it to generate hidden personas.
CHANNEL_SERVICE_URL=http://localhost:8001

# Default number of customers generated by POST /seed when ?count is omitted.
SEED_DEFAULT_COUNT=500
